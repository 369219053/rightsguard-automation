<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/coordinate_tester_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000">

    <!-- 提示信息 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="40dp"
        android:orientation="vertical"
        android:background="@drawable/floating_window_background"
        android:padding="16dp"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 坐标测试模式"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点击屏幕任意位置查看坐标"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

    <!-- 坐标显示卡片 -->
    <LinearLayout
        android:id="@+id/coordinate_display_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/floating_window_background"
        android:padding="24dp"
        android:elevation="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅ 已获取坐标"
            android:textSize="14sp"
            android:textColor="@color/primary_blue"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:id="@+id/tv_coordinate_x"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="X: 0"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_coordinate_y"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Y: 0"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp" />

        <!-- 按钮组 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_use_coordinate"
                android:layout_width="100dp"
                android:layout_height="40dp"
                android:text="使用"
                android:textSize="14sp"
                android:textColor="@color/text_white"
                android:background="@drawable/button_primary"
                android:layout_marginEnd="8dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_cancel_coordinate"
                android:layout_width="100dp"
                android:layout_height="40dp"
                android:text="取消"
                android:textSize="14sp"
                android:textColor="@color/primary_blue"
                android:background="@drawable/button_outlined"
                android:textAllCaps="false" />

        </LinearLayout>

    </LinearLayout>

    <!-- 关闭按钮 -->
    <Button
        android:id="@+id/btn_close_tester"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:text="✕"
        android:textSize="24sp"
        android:textColor="@color/text_white"
        android:background="@drawable/floating_window_minimized"
        android:elevation="8dp"
        android:textAllCaps="false" />

</FrameLayout>

